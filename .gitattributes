* text=auto eol=lf

# ملفات bat لازم CRLF دائماً — Windows cmd.exe يفشل بقراءة نص عربي (UTF-8) مع نهايات أسطر LF
*.bat text eol=crlf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
